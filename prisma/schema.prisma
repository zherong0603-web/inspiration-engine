generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model ActivityLog {
  id         String   @id
  userId     String?
  action     String
  resource   String?
  resourceId String?
  metadata   String?
  ip         String?
  userAgent  String?
  duration   Int?
  status     String   @default("success")
  error      String?
  createdAt  DateTime @default(now())
  User       User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([action])
  @@index([userId])
}

model Category {
  id        String   @id
  name      String   @unique
  color     String?
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Content {
  id         String   @id
  userId     String
  title      String
  category   String
  type       String
  content    String
  transcript String?
  tags       String
  metadata   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContentType {
  id        String   @id
  name      String   @unique
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Creation {
  id        String   @id
  userId    String
  sourceIds String
  prompt    String
  result    String
  type      String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feedback {
  id        String   @id
  userId    String?
  type      String
  title     String
  content   String
  contact   String?
  status    String   @default("待处理")
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User?    @relation(fields: [userId], references: [id])
}

model IPProfile {
  id          String   @id
  userId      String
  name        String
  description String?
  persona     String
  style       String
  topics      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IPTemplate {
  id             String   @id
  name           String
  category       String
  persona        String
  style          String
  successCase    String
  keyStrategy    String
  targetAudience String
  contentThemes  String
  createdAt      DateTime @default(now())
  updatedAt      DateTime
}

model InviteCode {
  id        String    @id
  code      String    @unique
  createdBy String?
  usedBy    String?
  isUsed    Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime
}

model ScriptTemplate {
  id          String   @id
  name        String
  type        String
  structure   String
  example     String
  usageCount  Int      @default(0)
  successRate Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model TopicIdea {
  id            String   @id
  userId        String
  title         String
  description   String?
  platform      String   @default("通用")
  category      String
  status        String   @default("待创作")
  aiScore       Int      @default(0)
  angles        String?
  bestTime      String?
  expectedViews String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  User          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id          String        @id
  email       String        @unique
  password    String
  name        String?
  inviteCode  String?       @unique
  invitedBy   String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  phone       String?       @unique
  credits     Int?          @default(100)
  ActivityLog ActivityLog[]
  Content     Content[]
  Creation    Creation[]
  Feedback    Feedback[]
  IPProfile   IPProfile[]
  TopicIdea   TopicIdea[]
}

model ViralCase {
  id           String   @id
  title        String
  platform     String
  category     String
  content      String
  viewCount    Int
  likeCount    Int
  commentCount Int
  shareCount   Int
  publishDate  DateTime
  tags         String
  structure    String?
  keyPoints    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}
